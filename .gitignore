# ##############################################################################
# Gitignore untuk Smart RPP Generator Pro & AssessmentHub AI
# ##############################################################################

# --- Lingkungan & Kredensial Rahasia (Environment & Secrets) ---
# Jangan pernah mem-push file konfigurasi lokal, API key, atau kredensial
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
*.json-credentials
*service-account*.json
credentials.json

# --- Dependensi Node.js / Paket (Dependencies) ---
# Diabaikan jika nanti ditambahkan NPM/Yarn untuk build tools atau tests
node_modules/
/jspm_packages/
/web_modules/
.npm/
.eslintcache
.parcel-cache/
.cache/

# --- Log & Berkas Sementara (Logs & Temp Files) ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
*.bak
*.swp
*~

# --- Editor & IDE ---
# VS Code
.vscode/
!.vscode/extensions.json
.history/
*.code-workspace

# JetBrains (WebStorm, PhpStorm, IntelliJ, PyCharm, dll)
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --- Sistem Operasi (OS Specific) ---
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# --- Python & Virtual Environment (Jika menggunakan skrip bantu) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.mypy_cache/

# --- Antigravity IDE / Gemini Workspace Cache ---
.gemini/
